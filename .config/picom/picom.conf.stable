backend = "glx";
vsync = true;

shadow = false;
shadow-radius = = 8;
shadow-opacity = 0.5;
shadow-offset-x = -5;
shadow-offset-y = -5;

fading = false;

rounded-corners = false;

inactive-opacity = 0.85;
inactive-opacity-override = false;

opacity-rule = [
  "90:class_g = 'Alacritty'",
  "90:class_g = 'URxvt'"
];

wintypes = {
  menu = { shadow = false; }
  dropdown_menu = { shadow = false; }
  popup_menu = { shadow = false; }
  utility = { shadow = false; }
};
